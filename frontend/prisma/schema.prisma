/**
 * =====================================================
 * FILE: prisma/schema.prisma
 * PROJECT: Burney Real Estate Portal
 *
 * PURPOSE:
 * Main database schema for Burney Real Estate Portal.
 *
 * CURRENT MODULES:
 * - Users
 * - Properties
 * - Developers
 * - Property Images
 * - Saved Properties
 * - Leads
 * =====================================================
 */

generator client {
  provider = "prisma-client-js"
}

/**
 * Prisma 7:
 * Database connection URL is managed from prisma.config.ts
 */
datasource db {
  provider = "postgresql"
}

/**
 * -----------------------------------------------------
 * USER ROLES
 * -----------------------------------------------------
 */
enum UserRole {
  ADMIN
  AGENT
  USER
}

/**
 * -----------------------------------------------------
 * PROPERTY CATEGORY
 * -----------------------------------------------------
 */
enum PropertyCategory {
  BUY
  RENT
  OFFPLAN
}

/**
 * -----------------------------------------------------
 * PROPERTY STATUS
 * -----------------------------------------------------
 */
enum PropertyStatus {
  AVAILABLE
  LIMITED
  SOLD
}

/**
 * -----------------------------------------------------
 * PROPERTY APPROVAL STATUS
 * -----------------------------------------------------
 * Agent uploaded properties will need admin approval.
 * -----------------------------------------------------
 */
enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

/**
 * -----------------------------------------------------
 * LEAD STATUS
 * -----------------------------------------------------
 */
enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  CLOSED
  LOST
}

/**
 * -----------------------------------------------------
 * USER TABLE
 * -----------------------------------------------------
 */
model User {
  id       String   @id @default(cuid())
  name     String?
  email    String   @unique
  phone    String?
  password String?
  role     UserRole @default(USER)

  properties      Property[]
  savedProperties SavedProperty[]
  leads           Lead[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * -----------------------------------------------------
 * DEVELOPER TABLE
 * -----------------------------------------------------
 * Stores developer information.
 * Off-plan projects will be linked with developers.
 * -----------------------------------------------------
 */
model Developer {
  id          String  @id @default(cuid())
  name        String  @unique
  slug        String  @unique
  logo        String?
  description String?
  website     String?

  properties Property[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * -----------------------------------------------------
 * PROPERTY TABLE
 * -----------------------------------------------------
 * Stores Buy, Rent, and Off-plan properties.
 * -----------------------------------------------------
 */
model Property {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  description String?
  category    PropertyCategory
  status      PropertyStatus   @default(AVAILABLE)

  approvalStatus ApprovalStatus @default(PENDING)

  price     Float?
  bedrooms  String?
  bathrooms Int?
  size      Float?

  emirate  String?
  district String?
  type     String?

  developerId String?
  developer   Developer? @relation(fields: [developerId], references: [id])

  agentId String?
  agent   User?   @relation(fields: [agentId], references: [id])

  images          PropertyImage[]
  leads           Lead[]
  savedProperties SavedProperty[]

  crmId     String? @unique
  isFromCRM Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/**
 * -----------------------------------------------------
 * PROPERTY IMAGE TABLE
 * -----------------------------------------------------
 * Stores multiple images per property.
 * -----------------------------------------------------
 */
model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  alt        String?
  order      Int      @default(0)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

/**
 * -----------------------------------------------------
 * SAVED PROPERTY TABLE
 * -----------------------------------------------------
 * Allows registered users to save/favorite properties.
 * -----------------------------------------------------
 */
model SavedProperty {
  id String @id @default(cuid())

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([userId, propertyId])
}

/**
 * -----------------------------------------------------
 * LEAD TABLE
 * -----------------------------------------------------
 * Stores all property inquiries.
 *
 * Off-plan leads go to admin.
 * Buy/Rent leads go to uploading agent.
 * -----------------------------------------------------
 */
model Lead {
  id String @id @default(cuid())

  name    String
  email   String?
  phone   String
  message String?

  status LeadStatus @default(NEW)

  propertyId String?
  property   Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  assignedToId String?
  assignedTo   User?   @relation(fields: [assignedToId], references: [id], onDelete: SetNull)

  source String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
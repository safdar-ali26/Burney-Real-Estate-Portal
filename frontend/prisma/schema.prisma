/**
 * =====================================================
 * FILE: prisma/schema.prisma
 * PROJECT: Burney Real Estate Portal
 * PURPOSE:
 * This file defines the database structure for the project.
 *
 * Current Phase:
 * Week 1 - Foundation
 *
 * This initial schema includes:
 * - User roles
 * - Property categories
 * - Property status
 * - Users table
 * - Properties table
 * =====================================================
 */

/**
 * -----------------------------------------------------
 * PRISMA CLIENT GENERATOR
 * -----------------------------------------------------
 * This generates Prisma Client automatically.
 * Prisma Client will be used in Next.js to talk to database.
 * -----------------------------------------------------
 */
generator client {
  provider = "prisma-client-js"
}

/**
 * -----------------------------------------------------
 * DATABASE CONNECTION
 * -----------------------------------------------------
 * Prisma 7 me database URL yahan nahi hota.
 * DATABASE_URL prisma.config.ts file se load hota hai.
 * -----------------------------------------------------
 */
datasource db {
  provider = "postgresql"
}

/**
 * -----------------------------------------------------
 * USER ROLES
 * -----------------------------------------------------
 * ADMIN = Full website control
 * AGENT = Can upload Buy/Rent properties
 * USER  = Normal registered website user
 * -----------------------------------------------------
 */
enum UserRole {
  ADMIN
  AGENT
  USER
}

/**
 * -----------------------------------------------------
 * PROPERTY CATEGORIES
 * -----------------------------------------------------
 * BUY     = Secondary properties for sale
 * RENT    = Rental properties
 * OFFPLAN = Off-plan projects from CRM
 * -----------------------------------------------------
 */
enum PropertyCategory {
  BUY
  RENT
  OFFPLAN
}

/**
 * -----------------------------------------------------
 * PROPERTY STATUS
 * -----------------------------------------------------
 * AVAILABLE = Property is available
 * LIMITED   = Limited availability
 * SOLD      = Property is sold
 * -----------------------------------------------------
 */
enum PropertyStatus {
  AVAILABLE
  LIMITED
  SOLD
}

/**
 * -----------------------------------------------------
 * USER TABLE
 * -----------------------------------------------------
 * This table stores Admins, Agents, and Users.
 * Role field decides user permissions.
 * -----------------------------------------------------
 */
model User {
  // Unique user ID generated automatically
  id String @id @default(cuid())

  // User full name
  name String?

  // User email address, used for login
  email String @unique

  // User phone number
  phone String?

  // Password will be saved in encrypted form
  password String?

  // User role: ADMIN, AGENT, or USER
  role UserRole @default(USER)

  // One user/agent can have many properties
  properties Property[]

  // Date when user was created
  createdAt DateTime @default(now())

  // Date when user was last updated
  updatedAt DateTime @updatedAt
}

/**
 * -----------------------------------------------------
 * PROPERTY TABLE
 * -----------------------------------------------------
 * This table stores Buy, Rent, and Off-plan properties.
 * Off-plan properties will come from CRM.
 * Buy/Rent properties will be uploaded by agents.
 * -----------------------------------------------------
 */
model Property {
  // Unique property ID generated automatically
  id String @id @default(cuid())

  // Property title
  title String

  // SEO-friendly URL slug
  slug String @unique

  // Property description
  description String?

  // Property category: BUY, RENT, OFFPLAN
  category PropertyCategory

  // Property status: AVAILABLE, LIMITED, SOLD
  status PropertyStatus @default(AVAILABLE)

  // Property price
  price Float?

  // Bedrooms, example: Studio, 1 BR, 2 BR
  bedrooms String?

  // Number of bathrooms
  bathrooms Int?

  // Property size in square feet
  size Float?

  // Emirate, example: Dubai, Abu Dhabi, Sharjah
  emirate String?

  // District, example: Al Jaddaf, Dubai South
  district String?

  // Property type, example: Apartment, Villa, Townhouse
  type String?

  // Developer name, example: Emaar, DAMAC, Azizi
  developer String?

  // Property image URLs
  images String[]

  // Agent ID for Buy/Rent properties
  agentId String?

  // Relation with User table
  agent User? @relation(fields: [agentId], references: [id])

  // Date when property was created
  createdAt DateTime @default(now())

  // Date when property was last updated
  updatedAt DateTime @updatedAt
}